<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📞 WhatsApp Auto Answer"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:gravity="center"
            android:paddingBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Raspunde automat la apeluri WhatsApp"
            android:textSize="14sp"
            android:textColor="#757575"
            android:gravity="center"
            android:paddingBottom="24dp"/>

        <!-- STATUS CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:padding="16dp"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STATUS"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#9E9E9E"
                android:paddingBottom="8dp"/>

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⏳ Se verifica..."
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="12dp"/>

            <!-- Instructiuni pentru activare -->
            <LinearLayout
                android:id="@+id/tv_instructions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFF3E0"
                android:padding="12dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚠️ Cum sa activezi:"
                    android:textStyle="bold"
                    android:textColor="#E65100"
                    android:paddingBottom="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. Apasa butonul 'ACTIVEAZA ACUM'\n2. In lista de servicii, cauta 'WhatsApp Auto Answer'\n3. Apasa pe el si activeaza\n4. Confirma cu OK\n5. Revino la aceasta aplicatie"
                    android:textColor="#BF360C"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>

            <Button
                android:id="@+id/btn_open_accessibility"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="#1A237E"
                android:textColor="#FFFFFF"
                android:text="⚙️ Setari Accesibilitate"
                android:textSize="16sp"
                android:padding="14dp"/>
        </LinearLayout>

        <!-- SETARI CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:padding="16dp"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SETARI"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#9E9E9E"
                android:paddingBottom="16dp"/>

            <!-- Tip apel -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tip raspuns preferat:"
                android:textSize="16sp"
                android:textColor="#212121"
                android:paddingBottom="8dp"/>

            <RadioGroup
                android:id="@+id/radio_group_call_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="20dp">

                <RadioButton
                    android:id="@+id/radio_video"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🎥 Video"
                    android:textSize="16sp"
                    android:checked="true"/>

                <RadioButton
                    android:id="@+id/radio_audio"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🔊 Audio"
                    android:textSize="16sp"/>
            </RadioGroup>

            <!-- Delay -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Raspunde dupa:"
                    android:textSize="16sp"
                    android:textColor="#212121"/>

                <TextView
                    android:id="@+id/tv_delay_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2 secunde"
                    android:textSize="16sp"
                    android:textColor="#1A237E"
                    android:textStyle="bold"/>
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekbar_delay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:max="4"
                android:progress="1"/>

            <Button
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#4CAF50"
                android:textColor="#FFFFFF"
                android:text="💾 SALVEAZA SETARILE"
                android:textSize="16sp"
                android:padding="14dp"/>
        </LinearLayout>

        <!-- INFO CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#E8EAF6"
            android:padding="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ℹ️ Informatii"
                android:textStyle="bold"
                android:textColor="#1A237E"
                android:paddingBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Functioneaza cu WhatsApp si WhatsApp Business\n• Compatibil cu tablete Huawei EMUI/HarmonyOS\n• Daca 'Video' nu e disponibil, raspunde automat la Audio\n• Serviciul ramane activ si dupa repornire\n• Nu consuma baterie semnificativa"
                android:textColor="#283593"
                android:lineSpacingExtra="4dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
